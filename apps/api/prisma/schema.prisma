generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SUPER_ADMIN
  DOCTOR_ADMIN
  DOCTOR
  STAFF
  PATIENT
}

enum UserStatus {
  PENDING_APPROVAL
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum DoctorRequestedRole {
  DOCTOR_ADMIN
  DOCTOR
}

enum DoctorApplicationStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
  NEEDS_CHANGES
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum PasswordResetChannel {
  EMAIL
  SMS
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

model User {
  id            String     @id @default(cuid())
  firstName     String
  lastName      String?
  email         String     @unique
  phone         String?    @unique
  passwordHash  String
  avatarUrl     String?
  role          UserRole   @default(PATIENT)
  status        UserStatus @default(ACTIVE)
  emailVerified Boolean    @default(false)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  doctor            Doctor?
  staffProfile      StaffProfile?
  doctorApplication DoctorApplication? @relation("DoctorApplicationApplicant")

  administeredClinics Clinic[] @relation("ClinicAdminDoctor")

  reviewedDoctorApplications DoctorApplication[] @relation("DoctorApplicationReviewer")

  verifiedDoctors Doctor[] @relation("DoctorVerifiedBy")

  passwordResetOtps PasswordResetOtp[]
  appointments      Appointment[]
}

model DoctorApplication {
  id     String @id @default(cuid())
  userId String @unique

  requestedRole     DoctorRequestedRole @default(DOCTOR)
  requestedClinicId String?

  clinicName         String
  clinicPhone        String?
  clinicEmail        String?
  clinicAddressLine1 String?
  clinicAddressLine2 String?
  clinicCity         String?
  clinicState        String?
  clinicPostalCode   String?
  clinicCountry      String  @default("India")

  qualification       String?
  specialization      String?
  registrationNumber  String?
  registrationCouncil String?
  experienceYears     Int?
  biography           String?

  profilePhotoUrl    String?
  registrationDocUrl String?
  degreeDocUrl       String?
  identityDocUrl     String?

  status       DoctorApplicationStatus @default(PENDING)
  reviewNote   String?
  reviewedById String?
  submittedAt  DateTime?
  reviewedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  applicant User @relation("DoctorApplicationApplicant", fields: [userId], references: [id], onDelete: Cascade)

  reviewedBy User? @relation("DoctorApplicationReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  requestedClinic Clinic? @relation("DoctorApplicationClinic", fields: [requestedClinicId], references: [id], onDelete: SetNull)

  doctor Doctor?

  @@index([status, createdAt])
  @@index([reviewedById])
  @@index([requestedClinicId])
  @@index([registrationNumber])
}

model PasswordResetOtp {
  id          String               @id @default(cuid())
  userId      String
  channel     PasswordResetChannel
  destination String
  otpHash     String
  expiresAt   DateTime
  attempts    Int                  @default(0)
  verifiedAt  DateTime?
  usedAt      DateTime?
  lastSentAt  DateTime             @default(now())
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, channel, createdAt])
  @@index([destination, createdAt])
  @@index([expiresAt])
}

model Clinic {
  id            String  @id @default(cuid())
  adminDoctorId String?

  name        String
  slug        String  @unique
  tagline     String?
  description String?
  phone       String?
  email       String?

  addressLine1 String?
  addressLine2 String?
  city         String?
  state        String?
  postalCode   String?
  country      String  @default("India")

  logoUrl  String?
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  adminDoctor User? @relation("ClinicAdminDoctor", fields: [adminDoctorId], references: [id], onDelete: SetNull)

  doctorApplications DoctorApplication[] @relation("DoctorApplicationClinic")

  doctors      Doctor[]
  staff        StaffProfile[]
  services     Service[]
  equipment    Equipment[]
  clinicHours  ClinicHour[]
  appointments Appointment[]

  @@index([adminDoctorId])
  @@index([city, state])
}

model Doctor {
  id            String  @id @default(cuid())
  userId        String  @unique
  clinicId      String
  applicationId String? @unique
  verifiedById  String?

  slug                String?  @unique
  fullName            String
  designation         String?
  qualification       String?
  specialization      String?
  experienceYears     Int?
  registrationNumber  String?  @unique
  registrationCouncil String?
  bio                 String?
  photoUrl            String?
  consultationFee     Decimal? @db.Decimal(10, 2)

  publicEmail String?
  publicPhone String?

  degrees     String[] @default([])
  education   String[] @default([])
  languages   String[] @default([])
  memberships String[] @default([])
  awards      String[] @default([])

  websiteUrl   String?
  instagramUrl String?
  signatureUrl String?

  isVerified          Boolean   @default(false)
  isPublic            Boolean   @default(false)
  isActive            Boolean   @default(true)
  availableForBooking Boolean   @default(true)
  profileCompletedAt  DateTime?
  verifiedAt          DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Restrict)

  application DoctorApplication? @relation(fields: [applicationId], references: [id], onDelete: SetNull)

  verifiedBy User? @relation("DoctorVerifiedBy", fields: [verifiedById], references: [id], onDelete: SetNull)

  services     DoctorService[]
  availability DoctorAvailability[]
  appointments Appointment[]

  @@index([clinicId])
  @@index([verifiedById])
  @@index([fullName])
  @@index([isVerified, isPublic, isActive])
}

model DoctorAvailability {
  id       String @id @default(cuid())
  doctorId String

  dayOfWeek           DayOfWeek
  startTime           String
  endTime             String
  slotDurationMinutes Int       @default(30)
  isAvailable         Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([doctorId, dayOfWeek, startTime, endTime])
  @@index([doctorId, dayOfWeek])
}

model StaffProfile {
  id       String @id @default(cuid())
  userId   String @unique
  clinicId String

  designation  String?
  employeeCode String?
  permissions  String[] @default([])
  isActive     Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId])
  @@index([employeeCode])
}

model Service {
  id       String @id @default(cuid())
  clinicId String

  name            String
  slug            String
  description     String?
  durationMinutes Int      @default(30)
  price           Decimal? @db.Decimal(10, 2)
  icon            String?
  imageUrl        String?
  isActive        Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  doctors DoctorService[]

  @@unique([clinicId, slug])
  @@index([clinicId])
}

model DoctorService {
  doctorId  String
  serviceId String

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([doctorId, serviceId])
  @@index([serviceId])
}

model ClinicHour {
  id        String    @id @default(cuid())
  clinicId  String
  dayOfWeek DayOfWeek
  openTime  String?
  closeTime String?
  isClosed  Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@unique([clinicId, dayOfWeek])
  @@index([clinicId])
}

model Equipment {
  id       String @id @default(cuid())
  clinicId String

  name        String
  description String?
  brand       String?
  modelNumber String?
  imageUrl    String?
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId])
}

model Appointment {
  id              String            @id @default(cuid())
  patientId       String
  clinicId        String
  doctorId        String?
  serviceName     String
  appointmentDate DateTime
  notes           String?
  status          AppointmentStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patient User @relation(fields: [patientId], references: [id], onDelete: Cascade)

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Restrict)

  doctor Doctor? @relation(fields: [doctorId], references: [id], onDelete: SetNull)

  @@index([patientId, appointmentDate])
  @@index([clinicId, appointmentDate])
  @@index([doctorId, appointmentDate])
  @@index([status])
}
